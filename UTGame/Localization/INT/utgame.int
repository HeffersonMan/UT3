;[ShowPowerups UTUIDataProvider_MenuOption]
;FriendlyName=Show Powerups
;Description=Toggle whether or not to display powerups on the HUD.

[ShowScoring UTUIDataProvider_MenuOption]
FriendlyName=Show Scoring
Description=Toggle whether or not to display the scoring table on the HUD.

[ShowLeaderboard UTUIDataProvider_MenuOption]
FriendlyName=Show Leaderboard
Description=Toggle whether or not to display the leaderboard on the HUD.

[ShowVehicleArmorCount UTUIDataProvider_MenuOption]
FriendlyName=Show Vehicle Armor
Description=Toggle whether or not to display the vehicle armor count on the HUD.

;///////////////
; Server Options
;///////////////
[DedicatedServer UTUIDataProvider_MenuOption]
FriendlyName=Dedicated Server
Description=Whether or not to start a dedicated server for this match.

[ServerType UTUIDataProvider_MenuOption]
FriendlyName=Server Type
Description=The type of server to start the game with.

[ServerType360 UTUIDataProvider_MenuOption]
FriendlyName=Server Type
Description=The type of server to start the game with.

[MaxPlayers_PC UTUIDataProvider_MenuOption]
FriendlyName=Max Players
Description=Maximum number of players to allow on the server.

[MaxPlayers_Console UTUIDataProvider_MenuOption]
FriendlyName=Max Players
Description=Maximum number of players to allow on the server.

[MinNumPlayers_PC UTUIDataProvider_MenuOption]
FriendlyName=Min Players
Description=Minimum number of players needed before the match starts.

[MinNumPlayers_Console UTUIDataProvider_MenuOption]
FriendlyName=Min Players
Description=Minimum number of players needed before the match starts.

[PrivateSlots UTUIDataProvider_MenuOption]
FriendlyName=Private Slots
Description=Number of private slots to reserve on the server for invited players.

[AllowKeyboard UTUIDataProvider_MenuOption]
FriendlyName=Keyboard & Mouse
Description=Enable to allow players to use a keyboard and mouse in the game.

[ServerDescription UTUIDataProvider_MenuOption]
FriendlyName=Description
Description=Short description to display along with the hostname for this server in the server browser.

[ServerMOTD UTUIDataProvider_MenuOption]
FriendlyName=MOTD
Description=Message of the Day to display when a player joins the server.

[ServerPassword UTUIDataProvider_MenuOption]
FriendlyName=Server Password
Description=Password needed to connect to this server.  Leave blank for an unlocked server.


