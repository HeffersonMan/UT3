[UTMutator_NoOrbs UTUIDataProvider_Mutator]
FriendlyName="Keine Kugeln"
Description="Keine Kugeln in der Schlacht."

[UTMutator_FriendlyFire UTUIDataProvider_Mutator]
FriendlyName="Teamschaden"
Description="Teamschaden richtet bei Teamkameraden 50 percent Schaden an."

[UTMutator_Handicap UTUIDataProvider_Mutator]
FriendlyName="Handicap"
Description="Versorgt die unterlegenen Spieler mit Rüstungs- und Waffenvorteilen."

[UTMutator_Instagib UTUIDataProvider_Mutator]
FriendlyName="Instagib"
Description="Spieler erhalten eine Ein-Schuss Instagib-Gewehr und alle Pickups werden vom Spiel entfernt."

[UTMutator_LowGrav UTUIDataProvider_Mutator]
FriendlyName="Schwerkraft"
Description="Schwerkraft wurde herabgesetzt."

[UTMutator_NoHoverboard UTUIDataProvider_Mutator]
FriendlyName="Kein Hoverboard"
Description="Hoverboard wurde entfernt."

[UTMutator_NoPowerups UTUIDataProvider_Mutator]
FriendlyName="Keine Super-Pickups"
Description="Entfernt alle Super-Aufnahmestellen (Schutzschildgürtel, Powerups, Mega-Gesundheitspacks, Redeemer) aus dem Spiel."

[UTMutator_NoTranslocator UTUIDataProvider_Mutator]
FriendlyName="Kein Translokator"
Description="Das Translokatorgerät wurde aus dem Inventar der Spieler entfernt."

[UTMutator_Slomo UTUIDataProvider_Mutator]
FriendlyName="Zeitlupe"
Description="Verlangsamt den Spielablauf."

[UTMutator_SlowTimeKills UTUIDataProvider_Mutator]
FriendlyName="Kills Verlangsamt den Zeitablauf"
Description="Die Zeit verlangsamt sich kurzzeitig für jede Tötung eines Feindes (nur für Schnelles Spiel)."

[UTMutator_SpeedFreak UTUIDataProvider_Mutator]
FriendlyName="Geschwindigkeit"
Description="Erhöht die Geschwindigkeit des Spiels."

[UTMutator_SuperBerserk UTUIDataProvider_Mutator]
FriendlyName="Super-Berserk"
Description="Spieler bekommen Berserk für das gesamte Spiel."

[UTMutator_Survival UTUIDataProvider_Mutator]
FriendlyName="Überleben"
Description="Zuschauende Spieler werden ins Spiel eingebracht, wenn momentane Spieler getötet werden (nur im Duell-Modus)."

[UTMutator_WeaponReplacement UTUIDataProvider_Mutator]
FriendlyName="Waffenauswechslung"
Description="Standardwaffen in einem Level können durch verschiedene Waffen ersetzt werden."

[UTMutator_WeaponsRespawn UTUIDataProvider_Mutator]
FriendlyName="Waffen Wiedergeburt"
Description="Waffen werden wiedergeboren anstatt ständig verfügbar zu sein."

[UTMutator_Hero UTUIDataProvider_Mutator]
FriendlyName="Titan"
Description="Ermöglicht es Spielern, Titanen zu werden."


